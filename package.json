{
  "name": "mcp-jira-labels",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal MCP server for adding and removing Jira issue labels.",
  "type": "module",
  "bin": {
    "mcp-jira-labels": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --target node20 --out-dir dist --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
